# Featherless AI Configuration
# Copy this file to .env and fill in your API key

# Get your API key from https://featherless.ai
FEATHERLESS_API_KEY=your-featherless-api-key-here

# Choose your model (OpenAI-compatible model names from Featherless AI catalog)
# Cost-efficient options:
#   meta-llama/Meta-Llama-3.1-8B-Instruct   (fast, cheap)
#   Qwen/Qwen2.5-7B-Instruct                (fast, cheap)
# Higher quality options:
#   meta-llama/Meta-Llama-3.3-70B-Instruct  (best quality)
#   Qwen/Qwen2.5-72B-Instruct               (excellent reasoning)
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# MongoDB Atlas (cloud — works locally and on HF Spaces)
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=your-app

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── SMTP for Password Reset OTP ─────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Agentic Research Bot
