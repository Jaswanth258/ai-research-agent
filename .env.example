# Featherless AI Configuration
# Copy this file to .env and fill in your API key

# Get your API key from https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_api_key_here

# Choose your model (OpenAI-compatible model names from Featherless AI catalog)
# Cost-efficient options:
#   meta-llama/Meta-Llama-3.1-8B-Instruct   (fast, cheap)
#   Qwen/Qwen2.5-7B-Instruct                (fast, cheap)
# Higher quality options:
#   meta-llama/Meta-Llama-3.3-70B-Instruct  (best quality)
#   Qwen/Qwen2.5-72B-Instruct               (excellent reasoning)
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
